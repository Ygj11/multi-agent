{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI Debug",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/agent-development/.venv/bin/python",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host",
                "127.0.0.1",
                "--port",
                "8000"
            ],
            "cwd": "${workspaceFolder}/agent-development",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/agent-development"
            },
            "jinja": true,
            "justMyCode": false,
            "console": "integratedTerminal"
        }
    ]
}
