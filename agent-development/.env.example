# LLM
ENABLE_REAL_LLM=false
ENABLE_OPENSDK_LLM=false
INTERNAL_LLM_API_URL=
INTERNAL_LLM_MODEL=1501
INTERNAL_LLM_TIMEOUT=60
INTERNAL_LLM_MAX_TOKENS=8192
INTERNAL_LLM_TEMPERATURE=0.1

# Scene models
QUERY_REWRITE_MODEL=
INTENT_RECOGNITION_MODEL=
AGENT_SELECTION_MODEL=
SUBAGENT_REASONING_MODEL=
FINAL_COMPLIANCE_MODEL=
SUMMARY_MODEL=

# OpenAI compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30

# Knowledge API
ENABLE_KNOWLEDGE_API=false
KNOWLEDGE_API_URL=
KNOWLEDGE_API_TIMEOUT=10

# MCP
ENABLE_MCP_CLIENT=true
MCP_SERVERS_JSON=

# Storage
SQLITE_DB_PATH=.data/agent_mvp.sqlite3
CHECKPOINT_BACKEND=memory
CHECKPOINT_DB_PATH=

# Approval
MAX_APPROVAL_CHAIN_DEPTH=3
MAX_WRITE_TOOLS_PER_REQUEST=3
APPROVAL_SYSTEM_URL=http://mock-approval-system.local/api/approval/requests
APPROVAL_CALLBACK_URL=http://localhost:8000/api/approval/callback
APPROVAL_SYSTEM_TIMEOUT=30
ENABLE_EXTERNAL_APPROVAL=true

# HTTP tools
ENABLE_HTTP_TOOLS=false
ALLOWED_HTTP_TOOL_HOSTS=
HTTP_TOOL_TIMEOUT=5

# Tool loop safety
TOOL_LOOP_MAX_ITERATIONS=10
TOOL_LOOP_MAX_CONSECUTIVE_FAILURES=3
TOOL_LOOP_MAX_SAME_TOOL_FAILURES=2
TOOL_LOOP_MAX_DUPLICATE_CALLS=2
TOOL_WRITE_IDEMPOTENCY_ENABLED=true

# Security
ENABLE_SHELL_EXEC=false
AUTH_MODE=dev_header
ALLOW_REQUEST_BODY_IDENTITY_FALLBACK=true

# Skill
ENABLE_SKILL_LLM_RERANK=true
SKILL_LLM_RERANK_TOP_K=3
SKILL_LLM_RERANK_MIN_MARGIN=3
