# 配置优先级：系统环境变量 > 项目 .env > Settings 默认值。
# 生产推荐最小安全组合：
#   APP_ENV=prod
#   AUTH_MODE=required
#   ALLOW_REQUEST_BODY_IDENTITY_FALLBACK=false
#   TOOL_WRITE_IDEMPOTENCY_ENABLED=true

# Runtime
# local/test 默认允许开发便利能力；prod 会启用更严格的组合校验。
APP_ENV=local

# Security / identity
# AUTH_MODE=dev_header：本地/测试可信 Header 模式。
# AUTH_MODE=required 或 jwt：没有可信身份时直接 401。
# ALLOW_REQUEST_BODY_IDENTITY_FALLBACK=true 只建议本地开发；prod 必须为 false。
ENABLE_SHELL_EXEC=false
AUTH_MODE=dev_header
ALLOW_REQUEST_BODY_IDENTITY_FALLBACK=true

# LLM provider
# ENABLE_OPENSDK_LLM=true 表示选择 OpenAI-compatible Provider，必须配置 OPENAI_API_KEY。
# ENABLE_REAL_LLM=true 表示“要求真实 LLM 上游”；若未启用 OpenSDK，则必须配置 INTERNAL_LLM_API_URL。
# 本地无 LLM 调试：ENABLE_REAL_LLM=false、ENABLE_OPENSDK_LLM=false、INTERNAL_LLM_API_URL 留空。
ENABLE_REAL_LLM=false
ENABLE_OPENSDK_LLM=false
INTERNAL_LLM_API_URL=
INTERNAL_LLM_MODEL=1501
INTERNAL_LLM_TIMEOUT=60
INTERNAL_LLM_MAX_TOKENS=8192
INTERNAL_LLM_TEMPERATURE=0.1

# OpenAI-compatible provider
# DeepSeek 示例：
#   ENABLE_OPENSDK_LLM=true
#   OPENAI_BASE_URL=https://api.deepseek.com
#   OPENAI_MODEL=deepseek-v4-pro
#   OPENAI_API_KEY=你自己的 key
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30

# Scene model overrides
# 为空时使用 Provider 默认模型；只有需要不同节点使用不同模型时才配置。
QUERY_REWRITE_MODEL=
INTENT_RECOGNITION_MODEL=
AGENT_SELECTION_MODEL=
SUBAGENT_REASONING_MODEL=
TASK_COMPLETION_MODEL=
FINAL_COMPLIANCE_MODEL=
SUMMARY_MODEL=

# Knowledge API
# ENABLE_KNOWLEDGE_API=true 必须配置 KNOWLEDGE_API_URL；否则启动期配置校验会失败。
ENABLE_KNOWLEDGE_API=false
KNOWLEDGE_API_URL=
KNOWLEDGE_API_TIMEOUT=10

# Tool implementation modes
# mock：使用本地 mock/fake handler，适合本地开发和 Agent 能力验证。
# real：使用真实上游 API，必须配置对应 base_url。
POS_TOOL_MODE=mock
TROUBLESHOOTING_TOOL_MODE=mock

# POS API
POS_API_BASE_URL=http://ehis-epos-gateway.paic.com.cn
POS_API_TIMEOUT=10

# Troubleshooting API
# TROUBLESHOOTING_TOOL_MODE=real 时必须配置 TROUBLESHOOTING_API_BASE_URL。
TROUBLESHOOTING_API_BASE_URL=
TROUBLESHOOTING_API_TIMEOUT=10

# MCP dynamic tools
# ENABLE_MCP_CLIENT=true 只是允许 MCP；只有 MCP_SERVERS_JSON/MCP_SERVERS 非空时才会发现外部工具。
# UNKNOWN_MCP_TOOL_POLICY 用于 MCP 工具缺少显式 operation/risk_level 时的处理：allow|approval|deny。
ENABLE_MCP_CLIENT=true
MCP_SERVERS_JSON=
UNKNOWN_MCP_TOOL_POLICY=allow

# Storage / checkpoint
# SQLITE_DB_PATH 是项目级消息、审批、工具日志、checkpoint snapshot 存储。
# CHECKPOINT_BACKEND 是 LangGraph 原生 checkpointer：memory|sqlite。
SQLITE_DB_PATH=.data/agent_mvp.sqlite3
CHECKPOINT_BACKEND=memory
CHECKPOINT_DB_PATH=

# Session concurrency
# ENABLE_SESSION_EXECUTION_LOCK=true 表示同一 session_key 的 Graph run 串行执行；
# 不同 session_key 仍可并发。第一版是进程内锁，多 worker/多实例不共享。
ENABLE_SESSION_EXECUTION_LOCK=true
SESSION_LOCK_TIMEOUT_SECONDS=60

# Approval
# ENABLE_EXTERNAL_APPROVAL=false 时不会真正提交外部审批系统，会返回本地 disabled 结果。
MAX_APPROVAL_CHAIN_DEPTH=3
MAX_WRITE_TOOLS_PER_REQUEST=3
APPROVAL_SYSTEM_URL=http://mock-approval-system.local/api/approval/requests
APPROVAL_CALLBACK_URL=http://localhost:8000/api/approval/callback
APPROVAL_SYSTEM_TIMEOUT=30
ENABLE_EXTERNAL_APPROVAL=true

# Admin HTTP tools
# ENABLE_HTTP_TOOLS=true 必须配置 ALLOWED_HTTP_TOOL_HOSTS，避免 LLM 任意发起外部请求。
ENABLE_HTTP_TOOLS=false
ALLOWED_HTTP_TOOL_HOSTS=
HTTP_TOOL_TIMEOUT=5

# Tool loop safety
TOOL_LOOP_MAX_ITERATIONS=10
TOOL_LOOP_MAX_CONSECUTIVE_FAILURES=3
TOOL_LOOP_MAX_SAME_TOOL_FAILURES=2
TOOL_LOOP_MAX_DUPLICATE_CALLS=2
TOOL_WRITE_IDEMPOTENCY_ENABLED=true

# Skill selection
# NO_SKILL_POLICY=clarify：未匹配 skill 时澄清。
# NO_SKILL_POLICY=answer_no_skill：允许无 skill 直接回答。
# NO_SKILL_POLICY=generic_dev_only：仅 APP_ENV=local 允许的开发兜底。
ENABLE_SKILL_LLM_RERANK=true
SKILL_LLM_RERANK_TOP_K=3
SKILL_LLM_RERANK_MIN_MARGIN=3
NO_SKILL_POLICY=clarify

# Intent taxonomy
# true：AgentCard / Skill route 必须覆盖 intent_taxonomy.yaml 中配置的合法范围。
STRICT_TAXONOMY_ROUTE_COVERAGE=true

# Task completion verify-repair loop
# ENABLE_TASK_COMPLETION_VERIFY=true 只是打开完成度验收节点。
# TASK_COMPLETION_ENABLE_LLM=true 还必须配合真实 LLM Provider，否则配置校验失败。
ENABLE_TASK_COMPLETION_VERIFY=true
TASK_COMPLETION_MAX_REPAIR_ROUNDS=2
TASK_COMPLETION_MIN_VERIFIER_CONFIDENCE=0.55
TASK_COMPLETION_ENABLE_LLM=false
TASK_COMPLETION_ENABLE_STATE_PROBES=true
# 默认复用 collect_verification_evidence 生成的证据；只有验收前必须重新查询最新业务状态时才开启。
TASK_COMPLETION_REFRESH_EVIDENCE_BEFORE_VERIFY=false
TASK_COMPLETION_FAIL_CLOSED=true

# Runtime observability
# LOG_DECISION_TRACE_IN_MESSAGES 会把决策摘要写入消息 metadata；生产环境默认不建议打开。
LOG_GRAPH_NODE_EVENTS=false
LOG_DISABLED_SERVICE_EVENTS=false
LOG_DECISION_TRACE_IN_MESSAGES=false
